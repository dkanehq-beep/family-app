rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(data) {
      return isSignedIn() && data.ownerUid == request.auth.uid;
    }

    // 게시판 글 + 댓글
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isOwner(resource.data);

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        // update은 누구나(댓글에 이모지 반응 달 때 필요), 삭제는 작성자만
        allow update: if isSignedIn();
        allow delete: if isOwner(resource.data);
      }

      // 이모지 반응 - 문서 id 자체가 본인 uid라서, 본인 문서만 쓸 수 있게 제한
      match /reactions/{uid} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // 캘린더 일정
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isOwner(resource.data);
    }

    // 여행 기록
    match /trips/{tripId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isOwner(resource.data);
    }

    // 공지사항
    match /announcements/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isOwner(resource.data);
    }

    // 숙제 (완료 체크는 가족 누구나, 삭제는 작성자만)
    match /homework/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isOwner(resource.data);
    }

    // 준비물 체크리스트 (완료 체크는 가족 누구나, 삭제는 작성자만)
    match /supplies/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isOwner(resource.data);
    }

    // 학원 (하루에 여러 곳 등록 가능, 삭제는 작성자만)
    match /academies/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isOwner(resource.data);
    }

    // 아이 목록 / 주간 시간표 (가족 공유 데이터)
    match /kids/{id} {
      allow read, write: if isSignedIn();
    }
    match /weekly_schedule/{id} {
      allow read, write: if isSignedIn();
    }

    // 마일리지
    match /mileage/{uid} {
      allow read, write: if isSignedIn();
    }
    match /mileage_log/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // 가족 투표
    match /polls/{pollId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isOwner(resource.data);

      match /votes/{voterUid} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == voterUid;
      }
    }

    // 오늘의 질문 체크인 (문서 id가 "본인uid_날짜"라서 본인 것만 쓸 수 있게 제한)
    match /checkins/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow delete: if false;
    }

    // 캘린더 일정(생일 등)에 남기는 축하 메시지
    match /event_wishes/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isOwner(resource.data);
    }

    // 프로필(아바타 이모지) - 문서 id가 본인 uid라서 본인 것만 쓸 수 있음
    match /profiles/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // 가족 편지함 - 받는 사람과 보낸 사람만 읽을 수 있음 (게시판처럼 전체공개 아님)
    match /letters/{id} {
      allow read: if isSignedIn() &&
        (resource.data.toUid == request.auth.uid || resource.data.ownerUid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if isSignedIn() &&
        (resource.data.toUid == request.auth.uid || resource.data.ownerUid == request.auth.uid);
    }

    // 장보기 · 할일 공유 리스트 (완료 체크는 가족 누구나, 삭제는 작성자만)
    match /todos/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isOwner(resource.data);
    }

    // 마일리지 리워드 상점 (교환 자체는 mileage/mileage_log 규칙으로 처리되고,
    // 여기는 리워드 "정의"만 관리 - 삭제는 만든 사람만)
    match /rewards/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if isOwner(resource.data);
    }

    // 위시리스트 (선물했는지 체크는 가족 누구나, 삭제는 작성자만)
    match /wishlist_items/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isOwner(resource.data);
    }

    // 그 외 컬렉션은 기본 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
